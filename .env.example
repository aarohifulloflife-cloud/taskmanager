# Copy to .env for local runs, or set these in EasyPanel's Environment tab.

# Port the API listens on
PORT=3000

# MongoDB connection string.
# Local docker-compose: mongodb://mongo:27017/taskmanager
# EasyPanel one-click Mongo: use the internal connection string EasyPanel shows
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/taskmanager
MONGODB_URI=mongodb://mongo:27017/taskmanager

# Auth
JWT_SECRET=change-me-to-a-long-random-string
DEMO_USER=demo
DEMO_PASS=demo123
