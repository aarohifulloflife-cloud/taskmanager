{
  "name": "taskmanager-devops-pipeline",
  "version": "1.0.0",
  "description": "RESTful Task Manager API with a full Jenkins DevOps pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "lint": "eslint src tests",
    "build": "echo \"No transpile step; build artefact is the Docker image\""
  },
  "keywords": [
    "devops",
    "jenkins",
    "express",
    "ci-cd"
  ],
  "author": "Aarohi Sewag Sharma",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
